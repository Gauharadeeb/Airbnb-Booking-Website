PORT=5000
CLIENT_URL=http://localhost:5173,http://localhost:5174,http://localhost:5175,https://airbnb-booking-website-gamma.vercel.app

MONGO_URL=mongodb://127.0.0.1:27017/airbnb_booking
# Optional when MONGO_URL does not include a database name, such as some Atlas URLs.
# MONGO_DATABASE=airbnb_booking

# Use local for development. Use cloudinary in production after certificate/network config is correct.
UPLOAD_PROVIDER=local
API_PUBLIC_URL=http://localhost:5000

JWT_SECRET_TOKEN=replace-with-a-long-random-secret
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
